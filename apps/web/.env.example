# Web Environment Configuration
# Copy this to .env.local and fill in your values

# Stripe Public Key (exposed on frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key_here

# API Base URL - Points to backend (Railway/Render/etc)
# For production deploy, set your actual backend URL
NEXT_PUBLIC_API_URL=https://fateful-chat-api-production.up.railway.app
# NEXT_PUBLIC_API_URL=http://localhost:5000

# Frontend Base URL (for redirects)
NEXT_PUBLIC_BASE_URL=https://your-frontend.vercel.app