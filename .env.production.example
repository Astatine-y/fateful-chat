# Production Environment Variables Template
# Copy this to .env.production and fill in values

# Required
JWT_SECRET=your-super-secret-jwt-key-min-32-changes-this-in-production
OPENAI_API_KEY=sk-your-openai-api-key
MONGODB_URI=mongodb://...

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_MONTHLY_PRICE_ID=price_xxx
STRIPE_YEARLY_PRICE_ID=price_xxx

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_CALLBACK_URL=https://your-api.up.railway.app/api/auth/google/callback

# Apple OAuth (optional, from Apple Developer)
APPLE_CLIENT_ID=xxx
APPLE_CLIENT_SECRET=xxx
APPLE_TEAM_ID=xxx
APPLE_KEY_ID=xxx

# URLs
FRONTEND_URL=https://your-frontend.vercel.app

# Server
NODE_ENV=production
PORT=5000